{
  "manifest_version": 3,
  "name": "Vimeo Gyorsito",
  "version": "1.0.0",
  "description": "Automatically speed up Vimeo videos",
  "content_scripts": [
    {
      "matches": ["*://*.vimeo.com/*", "*://player.vimeo.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
